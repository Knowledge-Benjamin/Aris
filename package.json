{
  "name": "aris-digital-brain",
  "private": true,
  "scripts": {
    "dev:server": "ts-node-dev --respawn --transpile-only server/src/server.ts",
    "dev:cli": "ts-node-dev --respawn --transpile-only cli/src/index.ts",
    "dev:search": "cd search-server && ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:whatsapp": "cd whatsapp-service && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:cli\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/server.js",
    "db:setup": "ts-node server/src/db/setup.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^134.0.0",
    "inquirer": "^9.2.9",
    "node-record-lpcm16": "^1.0.0",
    "openai": "^5.8.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/inquirer": "^9.0.5",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.6.0",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
