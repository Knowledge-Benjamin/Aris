# For pg@8.21+ and Neon/Postgres, include an explicit sslmode.
# Current default behavior: ?sslmode=verify-full
# For libpq compatibility, use ?uselibpqcompat=true&sslmode=require
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=verify-full
GEMMA_API_KEY=
GEMMA_API_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_SERVICE_URL=https://your-embedding-service-url
EMBEDDING_API_KEY=your-embedding-api-key
GEMMA_MODEL=gemma-4-26b-a4b-it
SERVER_PORT=4000
CLI_BASE_URL=http://localhost:4000
SEARCH_SERVICE_URL=http://localhost:8080
SEARCH_TOOL_ENABLED=true
SEARCH_TOOL_ENGINES=google,bing,duckduckgo,searx
SEARCH_SEARX_URL=
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback
# Use a fixed redirect URI registered in Google Cloud for CLI web OAuth.
# This should match the redirect URI used when generating your Google auth URL.
# Register this exact URI in your Google Cloud credentials and use the same value here.
GOOGLE_FALLBACK_REDIRECT_URI=http://127.0.0.1:8000/callback
VOICE_API_KEY=your-voice-api-key
VOICE_STT_URL=https://speech.googleapis.com/v1/speech:recognize
VOICE_TTS_URL=https://texttospeech.googleapis.com/v1/text:synthesize
VOICE_LANGUAGE_CODE=en-US
VOICE_TTS_VOICE=en-US-Wavenet-D
VOICE_TTS_AUDIO_ENCODING=MP3
TOMTOM_API_KEY=your-tomtom-api-key
